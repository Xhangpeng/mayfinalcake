{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A cake or bakery item for sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Birthday", "Anniversary", "Wedding", "Cupcakes", "Pastries", "Accessories", "Combos"] },
        "imageUrl": { "type": "string", "format": "uri" },
        "characteristics": { "type": "array", "items": { "type": "string" } },
        "inStock": { "type": "boolean" }
      },
      "required": ["name", "price", "category", "imageUrl", "inStock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order for cakes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "number" },
              "cakeName": { "type": "string" },
              "cakeDesign": { "type": "string" },
              "price": { "type": "number" }
            }
          }
        },
        "deliveryDetails": {
          "type": "object",
          "properties": {
            "fullName": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" },
            "deliveryDate": { "type": "string", "format": "date-time" },
            "deliveryTime": { "type": "string" }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "picked", "ready", "delivered", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "paymentMethod": { "type": "string", "enum": ["esewa", "khalti", "cod"] },
        "timeline": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "status": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "message": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "deliveryDetails", "totalAmount", "status", "paymentStatus"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "displayName", "role"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or admin notification for users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Target user ID, or 'all' for broadcast" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["targeted", "broadcast"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "senderId": { "type": "string" }
      },
      "required": ["userId", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "/products": {
      "schema": "Product",
      "description": "Catalog of cakes and items"
    },
    "/orders": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/users": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/notifications": {
      "schema": "Notification",
      "description": "User and broadcast notifications"
    }
  }
}
